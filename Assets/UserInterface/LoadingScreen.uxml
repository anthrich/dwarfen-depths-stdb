<ui:UXML xmlns:ui="UnityEngine.UIElements" editor-extension-mode="False">
    <Style src="LoadingScreen.uss" />
    <ui:VisualElement name="Root" style="flex-grow: 1; background-color: rgb(0, 0, 0); align-items: center; justify-content: center;">
        <ui:Label name="StatusLabel" text="Loading…" style="color: rgb(255, 255, 255); font-size: 20px;" />
        <ui:VisualElement class="progress-track">
            <ui:VisualElement name="ProgressFill" class="progress-fill" />
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
